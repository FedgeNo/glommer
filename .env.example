DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=glommer
DB_USERNAME=glommer
DB_PASSWORD=change-me
# The mail "from" address/name and the SMTP relay (strongly recommended over
# the mail() default for deliverability - see README) are both configured
# from the admin Site Settings page now, not here - there's nothing to set in
# .env for either. bin/install.php prompts for the "from" address the first
# time it isn't set anywhere yet.
SITE_URL=https://example.com
SITE_TITLE=Glommer
WS_HOST=0.0.0.0
WS_PORT=8090
WS_PUSH_PORT=8091
WS_SECRET=change-me
WS_TLS_CERT=
WS_TLS_KEY=
# Encrypts the ActivityPub (Fediverse-following) signing private key at rest
# in the database - bin/install.php generates this itself, along with the
# keypair, the first time it runs. Nothing to set here by hand.
ACTIVITYPUB_ENCRYPTION_KEY=
# How many media transcodes the upload-worker service runs at once (see
# bin/upload-worker.php). Bounds concurrent ffmpeg load; 2 is safe anywhere.
UPLOAD_WORKER_CONCURRENCY=2
# Optional: a MySQL admin account (CREATE/ALTER/DROP) used only for schema
# changes. Normally left empty - bin/install.php prompts for these when it has
# schema work to do. Fill them in to allow non-interactive upgrades: with both
# set, the site applies a pending schema migration itself on the first request
# after a deploy (see README's Upgrading section) instead of waiting behind a
# maintenance page for someone to run bin/install.php by hand.
DB_ADMIN_USERNAME=
DB_ADMIN_PASSWORD=
