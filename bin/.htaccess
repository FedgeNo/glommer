# CLI-only scripts (installer, upload worker, WebSocket daemon) - never web
# endpoints. Each also refuses to run outside the CLI SAPI; this is the same
# rule enforced at the web-server layer.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Deny from all
</IfModule>
