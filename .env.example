DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=glommer
DB_USERNAME=glommer
DB_PASSWORD=change-me
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=Glommer
# Optional SMTP relay - strongly recommended over the mail() default for
# deliverability (see README). Leave SMTP_HOST empty to use PHP's mail().
# SMTP_ENCRYPTION: tls (STARTTLS, port 587), ssl (implicit TLS, port 465), or none.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SITE_URL=https://example.com
SITE_TITLE=Glommer
WS_HOST=0.0.0.0
WS_PORT=8090
WS_PUSH_PORT=8091
WS_SECRET=change-me
WS_TLS_CERT=
WS_TLS_KEY=
